<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>SEUS — ลงเวลาด้วยใบหน้า</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.15/dist/face-api.js"></script>
<style>
:root{
  --cyan:#22BFD3;--cyan-d:#16A8BC;--cyan-l:#E4F7FA;
  --indigo:#5B4FE9;--indigo-l:#ECEAFE;
  --amber:#F6B43C;--amber-l:#FEF3E0;
  --rose:#EF6B6B;--rose-l:#FDECEC;
  --green:#3CC28A;--green-l:#E4F7EF;
  --bg:#E9F6FA;--ink:#2E3B44;--ink-2:#5E7079;--ink-3:#9AAAB3;
  --line:#E6EFF2;--sh:0 1px 3px rgba(46,59,68,.06),0 6px 20px rgba(46,59,68,.05);--r:14px;
}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--ink);font-family:'IBM Plex Sans Thai',system-ui,sans-serif;
  font-size:14.5px;line-height:1.55;-webkit-font-smoothing:antialiased}
.mono{font-family:'IBM Plex Mono',monospace;font-variant-numeric:tabular-nums}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input,select{font-family:inherit}
.hide{display:none!important}

.hero{background:var(--cyan);color:#fff;border-radius:var(--r);margin:16px 20px 0;padding:20px 26px;
  display:flex;align-items:center;gap:16px;box-shadow:var(--sh)}
.hero h1{font-size:24px;font-weight:700}
.hero .sub{font-size:12.5px;opacity:.9;margin-top:2px}
.hero .b{margin-left:auto;text-align:right}
.hero .b b{display:block;font-size:14px}.hero .b span{font-size:11px;opacity:.85}

nav{display:flex;gap:6px;padding:14px 20px 0;overflow-x:auto;scrollbar-width:none}
nav::-webkit-scrollbar{display:none}
nav button{padding:9px 17px;border-radius:999px;font-size:13.5px;font-weight:500;background:#fff;
  color:var(--ink-2);box-shadow:var(--sh);white-space:nowrap;min-height:42px}
nav button[aria-selected=true]{background:var(--indigo);color:#fff;font-weight:600}
nav .sp{margin-left:auto;display:flex;gap:8px}
.btn{padding:9px 16px;border-radius:999px;font-size:13px;font-weight:600;background:#fff;color:var(--ink-2);
  box-shadow:var(--sh);white-space:nowrap;min-height:42px}
.btn.go{background:var(--indigo);color:#fff}.btn.cy{background:var(--cyan);color:#fff}
.btn.rd{background:var(--rose);color:#fff}
.btn:disabled{opacity:.45;cursor:not-allowed}
main{padding:16px 20px 80px;max-width:1360px;margin:0 auto}

.head{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:16px;flex-wrap:wrap}
.head h2{font-size:21px;font-weight:600}
.head p{color:var(--ink-3);font-size:13px;max-width:70ch}
.kpis{display:flex;gap:10px;flex-wrap:wrap}
.kpi{background:#fff;border-radius:var(--r);box-shadow:var(--sh);padding:12px 16px;min-width:112px}
.kpi .k{font-size:11px;color:var(--ink-3)}
.kpi .v{font-family:'IBM Plex Mono';font-size:21px;font-weight:600}
.kpi.cy .v{color:var(--cyan-d)}.kpi.in .v{color:var(--indigo)}
.kpi.am .v{color:#B67B12}.kpi.ro .v{color:var(--rose)}.kpi.gr .v{color:#2A9169}

.panel{background:#fff;border-radius:var(--r);box-shadow:var(--sh);overflow:hidden;margin-bottom:16px}
.panel h3{padding:14px 20px;font-size:15px;font-weight:600;border-bottom:1px solid var(--line);
  display:flex;align-items:center;gap:10px}
.panel .in{padding:20px}
.tw{overflow-x:auto}.tw table{min-width:560px}
table{width:100%;border-collapse:collapse;font-size:13.5px}
th{text-align:left;padding:11px 16px;font-size:11px;text-transform:uppercase;letter-spacing:.05em;
  color:var(--ink-3);border-bottom:1px solid var(--line);font-weight:600;background:#F7FBFC}
td{padding:11px 16px;border-bottom:1px solid var(--line)}
tr:last-child td{border:none}
td.num,th.num{text-align:right;font-family:'IBM Plex Mono'}
.chip{font-size:11px;padding:3px 9px;border-radius:999px;background:var(--cyan-l);color:var(--cyan-d);
  font-weight:500;white-space:nowrap}
.chip.i{background:var(--indigo-l);color:var(--indigo)}
.chip.a{background:var(--amber-l);color:#B67B12}
.chip.r{background:var(--rose-l);color:#C94545}
.chip.g{background:var(--green-l);color:#2A9169}

.note{display:flex;gap:12px;border-radius:var(--r);padding:15px 18px;margin-bottom:16px;align-items:flex-start}
.note.priv{background:var(--green-l)}.note.priv b{color:#2A9169}
.note.err{background:var(--rose-l)}.note.err b{color:#C94545}
.note p{font-size:13px;color:var(--ink-2);margin-top:3px}
.note code{font-family:'IBM Plex Mono';font-size:12px;background:#fff;padding:1px 6px;border-radius:5px}

.cam{position:relative;background:#0E2027;border-radius:12px;overflow:hidden;aspect-ratio:4/3;display:grid;place-items:center}
.cam video{width:100%;height:100%;object-fit:cover;transform:scaleX(-1)}
.cam .ph{color:#7FA3AE;font-size:13.5px;text-align:center;padding:24px}
.cam .ring{position:absolute;inset:8%;border:3px dashed rgba(255,255,255,.35);border-radius:50%;pointer-events:none}
.cam.ok .ring{border-color:var(--green);border-style:solid}
.cam.bad .ring{border-color:var(--amber)}
.cam .hud{position:absolute;left:0;right:0;bottom:0;padding:11px 14px;
  background:linear-gradient(transparent,rgba(0,0,0,.7));color:#fff;font-size:13.5px;
  display:flex;justify-content:space-between;gap:10px}
.cam .hud .st{font-weight:600}
.shots{display:flex;gap:8px;margin-top:12px}
.shot{flex:1;aspect-ratio:1;border-radius:10px;border:2px dashed #CBDDE3;display:grid;place-items:center;
  font-size:11.5px;color:var(--ink-3);overflow:hidden;position:relative;background:#F7FBFC}
.shot img{width:100%;height:100%;object-fit:cover;transform:scaleX(-1)}
.shot.done{border:2px solid var(--green)}
.shot .lb{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.55);color:#fff;font-size:10px;padding:2px}

label.fl{display:block;font-size:12px;color:var(--ink-3);margin-bottom:5px;margin-top:12px}
label.fl:first-child{margin-top:0}
select,input.tx{width:100%;padding:12px 13px;border-radius:10px;border:1.5px solid var(--line);
  background:#FBFDFE;font-size:15px;color:var(--ink);min-height:48px}
select:focus,input.tx:focus{outline:none;border-color:var(--cyan)}
select.need,input.need{border-color:var(--rose);background:#FFF7F7}
.cibtns{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:14px}
.cibtn{padding:18px;border-radius:12px;font-size:16px;font-weight:700;color:#fff;min-height:60px}
.cibtn.i{background:var(--green)}.cibtn.o{background:var(--rose)}
.cibtn:disabled{opacity:.4;cursor:not-allowed}
.toast{margin-top:12px;padding:13px 15px;border-radius:10px;font-size:13.5px;display:none}
.toast.ok{display:block;background:var(--green-l);color:#2A9169}
.toast.no{display:block;background:var(--rose-l);color:#C94545}

.g3{display:grid;grid-template-columns:410px 1fr;gap:16px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:940px){.g3,.g2{grid-template-columns:1fr}}

.cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:14px}
.card{background:#fff;border-radius:var(--r);box-shadow:var(--sh);padding:19px 20px;text-align:left;width:100%;
  transition:transform .18s,box-shadow .18s;cursor:pointer}
.card:hover{transform:translateY(-3px);box-shadow:0 4px 10px rgba(46,59,68,.08),0 14px 34px rgba(46,59,68,.09)}
.card .code{font-family:'IBM Plex Mono';font-size:11px;color:var(--cyan-d);font-weight:600}
.card h3{font-size:17px;font-weight:600;margin:4px 0 2px;padding:0;border:none}
.card .cl{font-size:12.5px;color:var(--ink-3);min-height:19px}
.card .foot{display:flex;align-items:center;justify-content:space-between;margin-top:16px;gap:12px}
.ring2{width:58px;height:58px;position:relative;flex-shrink:0}
.ring2 svg{transform:rotate(-90deg)}
.ring2 b{position:absolute;inset:0;display:grid;place-items:center;font-family:'IBM Plex Mono';font-size:17px;font-weight:600}
.card .hrs{text-align:right}
.card .hrs b{font-family:'IBM Plex Mono';font-size:17px;color:var(--indigo);font-weight:600}
.card .hrs span{display:block;font-size:10.5px;color:var(--ink-3)}
.card.bo{border:2px solid var(--indigo)}

.board{display:grid;grid-template-columns:repeat(auto-fill,minmax(195px,1fr));gap:9px;padding:16px}
.pcell{border:1.5px solid var(--line);border-radius:12px;padding:12px 13px;cursor:pointer;min-height:68px}
.pcell:hover{border-color:var(--cyan)}
.pcell .nm{font-size:13px;font-weight:500;line-height:1.3}
.pcell .st{font-family:'IBM Plex Mono';font-size:11px;margin-top:4px;color:var(--ink-3)}
.pcell.in{background:var(--green-l);border-color:#BFE9D6}.pcell.in .st{color:#2A9169}
.pcell.out{background:var(--cyan-l);border-color:#C4EBF1}.pcell.out .st{color:var(--cyan-d)}
.pcell.late{background:var(--amber-l);border-color:#F6DFB4}.pcell.late .st{color:#B67B12}

.scrim{position:fixed;inset:0;background:rgba(30,45,52,.45);opacity:0;pointer-events:none;transition:.22s;z-index:40}
.scrim.open{opacity:1;pointer-events:auto}
.drawer{position:fixed;top:0;right:0;bottom:0;width:min(860px,100%);z-index:50;background:var(--bg);
  transform:translateX(100%);transition:transform .3s cubic-bezier(.2,.8,.2,1);display:flex;flex-direction:column;
  box-shadow:-8px 0 40px rgba(30,45,52,.2)}
.drawer.open{transform:none}
.dh{background:var(--cyan);color:#fff;padding:20px 24px;display:flex;align-items:flex-start;gap:14px}
.dh h2{font-size:21px}.dh .m{font-size:12.5px;opacity:.9;margin-top:2px}
.dh .x{margin-left:auto;font-size:26px;padding:0 8px}
.dstats{display:flex;background:#fff;overflow-x:auto}
.ds{flex:1;min-width:108px;padding:13px 18px;border-right:1px solid var(--line)}
.ds:last-child{border:none}
.ds .k{font-size:10.5px;color:var(--ink-3)}
.ds .v{font-family:'IBM Plex Mono';font-size:18px;font-weight:600}
.db{flex:1;overflow-y:auto;padding:14px}
@media(max-width:760px){
  .hero{margin:12px 12px 0;padding:16px;flex-wrap:wrap}.hero h1{font-size:20px}.hero .b{margin-left:0}
  nav{padding:12px 12px 0}main{padding:14px 12px 70px}
  .cards{grid-template-columns:1fr}.board{grid-template-columns:1fr 1fr}
  .drawer{width:100%}.kpi{flex:1;min-width:0}
}
@media(max-width:400px){.board{grid-template-columns:1fr}}
@media(prefers-reduced-motion:reduce){*{transition:none!important}}
</style>
</head>
<body>

<div class="hero">
  <div><h1>ลงเวลาด้วยใบหน้า</h1><div class="sub">SEUS Engineering Co., Ltd.</div></div>
  <div class="b"><b>SEUS</b><span>Electrical &amp; Instrumentation</span></div>
</div>

<nav>
  <button id="t-c" aria-selected="true" onclick="tab('c')">ลงเวลา</button>
  <button id="t-r" aria-selected="false" onclick="tab('r')">ลงทะเบียน</button>
  <button id="t-p" aria-selected="false" onclick="tab('p')">โครงการ</button>
  <button id="t-t" aria-selected="false" onclick="tab('t')">ตารางเวลา</button>
  <div class="sp">
    <button class="btn" onclick="document.getElementById('restore').click()">โหลดสำรอง</button>
    <button class="btn cy" onclick="dl()">ส่งออกข้อมูล</button>
  </div>
  <input type="file" id="restore" accept=".json" class="hide">
</nav>

<main>
<div class="note err hide" id="ctx">
  <span class="chip r">HTTPS</span>
  <div><b>เปิดจากไฟล์ในเครื่อง — กล้องใช้ไม่ได้</b>
    <p>เบราว์เซอร์อนุญาตให้ใช้กล้องเฉพาะเมื่อเปิดผ่าน <code>https://</code> หรือ <code>localhost</code>
    ต้องอัปขึ้น GitHub Pages ก่อน — นี่คือกฎความปลอดภัยของเบราว์เซอร์ ไม่ใช่ข้อจำกัดของระบบ</p></div>
</div>

<!-- ══ CHECK IN ══ -->
<div id="v-c">
  <div class="head">
    <div><h2>ลงเวลา</h2><p>เลือกโครงการ → มองกล้อง → ระบบจำได้เอง</p></div>
    <div class="kpis">
      <div class="kpi gr"><div class="k">เข้างานแล้ว</div><div class="v" id="k-in">0</div></div>
      <div class="kpi am"><div class="k">มาสาย</div><div class="v" id="k-late">0</div></div>
      <div class="kpi ro"><div class="k">ยังไม่ลงเวลา</div><div class="v" id="k-none">0</div></div>
    </div>
  </div>
  <div class="g3">
    <div class="panel">
      <h3>บันทึกเวลา <span class="chip mono" id="clk">--:--:--</span></h3>
      <div class="in">
        <label class="fl">โครงการ <b style="color:var(--rose)">*</b> — บังคับเลือกทุกครั้ง</label>
        <select id="proj" class="need" onchange="gate()"></select>
        <div class="cam" id="cam" style="margin-top:14px">
          <video id="vid" autoplay muted playsinline></video>
          <div class="ring"></div>
          <div class="ph" id="ph">กดเปิดกล้องด้านล่าง</div>
          <div class="hud hide" id="hud"><span class="st" id="hst">กำลังค้นหาใบหน้า…</span><span class="mono" id="hsc"></span></div>
        </div>
        <div class="cibtns">
          <button class="cibtn i" id="bIn" onclick="doPunch('in')" disabled>เข้างาน</button>
          <button class="cibtn o" id="bOut" onclick="doPunch('out')" disabled>ออกงาน</button>
        </div>
        <button class="btn cy" style="width:100%;margin-top:10px;min-height:46px" onclick="startCam('c')">เปิดกล้อง</button>
        <div class="toast" id="toast"></div>
      </div>
    </div>
    <div class="panel">
      <h3>สถานะวันนี้ <span style="font-weight:400;color:var(--ink-3);font-size:13px" id="today"></span></h3>
      <div class="board" id="board"></div>
    </div>
  </div>
</div>

<!-- ══ REGISTER ══ -->
<div id="v-r" class="hide">
  <div class="head">
    <div><h2>ลงทะเบียนพนักงาน</h2>
      <p>เก็บแค่ <b>ชื่อ · รหัส · ใบหน้า</b> เท่านั้น — ไม่มีเลขบัตรประชาชน ไม่มีเงินเดือน ไม่มีบัญชีธนาคาร</p></div>
    <div class="kpis">
      <div class="kpi cy"><div class="k">ลงทะเบียนแล้ว</div><div class="v" id="k-reg">0</div></div>
    </div>
  </div>

  <div class="note priv">
    <span class="chip g">PRIVACY</span>
    <div><b>ระบบลงเวลาไม่จำเป็นต้องรู้เงินเดือน</b>
      <p>มันต้องรู้แค่ <b>นี่คือใคร · ตอนนี้กี่โมง · โครงการไหน</b> — สามอย่างเท่านั้น<br>
      เงินเดือน เลขบัตร บัญชีธนาคาร อยู่ที่ระบบบัญชีของคุณ ไม่ต้องเอามาไว้ในนี้ และไม่ควรเอามา<br>
      <b>ข้อมูลที่ไม่ได้เก็บ คือข้อมูลที่รั่วไม่ได้</b></p></div>
  </div>

  <div class="g2">
    <div class="panel">
      <h3>เพิ่มพนักงาน</h3>
      <div class="in">
        <label class="fl">รหัสพนักงาน <b style="color:var(--rose)">*</b></label>
        <input class="tx mono" id="rcode" placeholder="SEUS001" oninput="rgate()">
        <label class="fl">ชื่อ–นามสกุล <b style="color:var(--rose)">*</b></label>
        <input class="tx" id="rname" placeholder="นายสมชาย ใจดี" oninput="rgate()">
        <label class="fl">ตำแหน่ง</label>
        <input class="tx" id="rpos" placeholder="ช่างไฟฟ้า">
        <label class="fl">ประเภท</label>
        <select id="rkind">
          <option value="direct">พนักงานหน้างาน — คิดเวลา ลงต้นทุนโครงการ</option>
          <option value="overhead">แบ็คออฟฟิศ — คิดเวลา ลงค่าดำเนินงาน</option>
          <option value="exempt">ผู้บริหาร — ลงเวลาได้ แต่ไม่นำมาคิด</option>
        </select>

        <div class="cam" id="rcam" style="margin-top:14px">
          <video id="rvid" autoplay muted playsinline></video>
          <div class="ring"></div>
          <div class="ph" id="rph">กรอกชื่อและรหัสก่อน แล้วเปิดกล้อง</div>
          <div class="hud hide" id="rhud"><span class="st" id="rhst">—</span></div>
        </div>
        <div class="shots">
          <div class="shot" id="s0"><span>หน้าตรง</span></div>
          <div class="shot" id="s1"><span>เอียงซ้าย</span></div>
          <div class="shot" id="s2"><span>เอียงขวา</span></div>
        </div>
        <button class="cibtn i" id="bShot" onclick="capture()" disabled style="width:100%;margin-top:12px">ถ่ายภาพ (0/3)</button>
        <button class="btn cy" style="width:100%;margin-top:10px;min-height:46px" id="bRcam" onclick="startCam('r')" disabled>เปิดกล้อง</button>
        <div class="toast" id="rtoast"></div>
      </div>
    </div>

    <div class="panel">
      <h3>รายชื่อที่ลงทะเบียนแล้ว</h3>
      <div class="tw"><table>
        <thead><tr><th>รหัส</th><th>ชื่อ</th><th>ตำแหน่ง</th><th>ประเภท</th><th></th></tr></thead>
        <tbody id="rlist"></tbody></table></div>
    </div>
  </div>
</div>

<!-- ══ PROJECTS ══ -->
<div id="v-p" class="hide">
  <div class="head"><div><h2>ชั่วโมงตามโครงการ</h2>
    <p>ชั่วโมงจริงจากบัตรตอก — ไม่ใช่เงิน เพราะระบบนี้ไม่รู้จักเงินเดือน<br>
    เอาชั่วโมงนี้ไปคูณอัตราในระบบบัญชีของคุณ</p></div></div>
  <div class="cards" id="grid"></div>
</div>

<!-- ══ TIMESHEET ══ -->
<div id="v-t" class="hide">
  <div class="head"><div><h2>ตารางเวลาทำงาน</h2>
    <p>08:00–17:00 · พัก 60 นาที · ผ่อนผัน 15 นาที · กดที่ชื่อเพื่อดูรายวัน</p></div>
    <button class="btn cy" onclick="csv()">ส่งออก CSV ให้บัญชี</button></div>
  <div class="panel"><div class="tw"><table>
    <thead><tr><th>พนักงาน</th><th class="num">วัน</th><th class="num">ชม.รวม</th><th class="num">สาย (น.)</th>
      <th class="num">OT (หลักฐาน)</th><th>โครงการ</th><th>ล่าสุด</th></tr></thead>
    <tbody id="ts"></tbody></table></div></div>
</div>

</main>
<div class="scrim" id="scrim" onclick="closeD()"></div>
<aside class="drawer" id="drawer" role="dialog" aria-modal="true"></aside>

<script>
/* ═════════════════════════════════════════════════════════════════════════
   SEUS — attendance only.

   WHAT THIS SYSTEM KNOWS ABOUT A MAN:
     his name, his employee code, a 128-number vector of his face,
     and when he punched, and on which project.

   WHAT IT DOES NOT KNOW, AND MUST NOT:
     his national ID, his salary, his bank account, his children, his address.

   Attendance does not need any of that. It never did. Payroll lives in your
   accounting system; this exports HOURS and the accounting system multiplies
   them by a rate it already holds.

   Data you do not collect is data that cannot leak. That is the whole argument,
   and it is why this file can sit in a public repo and lose you nothing.
   ═════════════════════════════════════════════════════════════════════════ */

let EMP = [];

const PROJECTS = [
  {id:'P1',code:'PRJ-01',name:'โครงการ 1',kind:'project'},
  {id:'P2',code:'PRJ-02',name:'โครงการ 2',kind:'project'},
  {id:'P3',code:'PRJ-03',name:'โครงการ 3',kind:'project'},
  {id:'P4',code:'PRJ-04',name:'โครงการ 4',kind:'project'},
  {id:'P5',code:'PRJ-05',name:'โครงการ 5',kind:'project'},
  {id:'BO',code:'BACK-OFFICE',name:'Back Office / รอประมูลงาน',kind:'overhead'},
];

const SCH = {start:8*60, end:17*60, brk:60, grace:15, std:480};
const THRESHOLD = 0.50;

let stream=null, models=false, matched=null, shots=[], loop=null, pending=null;

const pad=n=>String(n).padStart(2,'0');
const dstr=d=>`${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
const tstr=d=>`${pad(d.getHours())}:${pad(d.getMinutes())}`;

/* ── Storage: local only. Never leaves this browser. ── */
const KEY='seus.attendance.v2';
function save(){ try{ localStorage.setItem(KEY, JSON.stringify(EMP)); }catch(e){} }
function load(){ try{ const r=localStorage.getItem(KEY); if(r) EMP=JSON.parse(r); }catch(e){} }
function dl(){
  const b=new Blob([JSON.stringify(EMP,null,2)],{type:'application/json'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(b);
  a.download='seus-attendance-'+dstr(new Date())+'.json'; a.click();
}
document.getElementById('restore').onchange = e=>{
  const f=e.target.files[0]; if(!f) return;
  const r=new FileReader();
  r.onload=ev=>{ try{ EMP=JSON.parse(ev.target.result); save(); all();
    toast('ok',`โหลดสำรองสำเร็จ — ${EMP.length} คน`); tab('c'); }
    catch(err){ toast('no','ไฟล์ไม่ถูกต้อง'); } };
  r.readAsText(f);
};

/* Hours out, money nowhere. Accounting already knows the rates. */
function csv(){
  const rows=[['รหัส','ชื่อ','วันที่','เข้า','ออก','โครงการ','นาทีทำงาน','นาทีสาย','นาที OT (หลักฐาน)','สถานะ']];
  EMP.forEach(e=>days(e).forEach(d=>rows.push([
    e.code, e.name, d.date, d.in?.time||'', d.out?.time||'', d.proj,
    d.worked, d.late, d.ot, d.incomplete?'ลืมลงเวลาออก':'ปกติ'
  ])));
  const csv='\uFEFF'+rows.map(r=>r.map(c=>`"${String(c).replace(/"/g,'""')}"`).join(',')).join('\n');
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download='seus-timesheet-'+dstr(new Date())+'.csv'; a.click();
}

/* ── Face ── */
async function loadModels(){
  if(models) return;
  const U='https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.15/model';
  await faceapi.nets.tinyFaceDetector.loadFromUri(U);
  await faceapi.nets.faceLandmark68Net.loadFromUri(U);
  await faceapi.nets.faceRecognitionNet.loadFromUri(U);
  models=true;
}
async function startCam(w){
  if(!window.isSecureContext) return toast('no','ต้องเปิดผ่าน https:// — เบราว์เซอร์ไม่ให้เปิดกล้องจากไฟล์ในเครื่อง', w);
  try{
    document.getElementById(w==='c'?'ph':'rph').textContent='กำลังโหลดโมเดลใบหน้า…';
    await loadModels();
    stream = await navigator.mediaDevices.getUserMedia({video:{facingMode:'user',width:640,height:480}});
    document.getElementById(w==='c'?'vid':'rvid').srcObject = stream;
    document.getElementById(w==='c'?'ph':'rph').classList.add('hide');
    document.getElementById(w==='c'?'hud':'rhud').classList.remove('hide');
    w==='c' ? idLoop() : regLoop();
  }catch(err){ toast('no','เปิดกล้องไม่ได้: '+err.message, w); }
}

/* 1:N identification. Kiosk mode.
   The Flutter app does 1:1 against a bound phone with a signed payload — that
   is stronger, and it is what the men on the scaffold should use. This screen
   is for the office and the site cabin. */
async function idLoop(){
  const v=document.getElementById('vid'), cam=document.getElementById('cam');
  clearInterval(loop);
  loop = setInterval(async ()=>{
    if(!v.videoWidth) return;
    const d = await faceapi.detectSingleFace(v, new faceapi.TinyFaceDetectorOptions({inputSize:320}))
      .withFaceLandmarks().withFaceDescriptor();
    if(!d){ matched=null; cam.className='cam bad';
      document.getElementById('hst').textContent='ไม่พบใบหน้า — มองตรงกล้อง';
      document.getElementById('hsc').textContent=''; return gate(); }
    let best=null, bd=99;
    for(const e of EMP) for(const f of e.face){
      const dist = faceapi.euclideanDistance(d.descriptor, f);
      if(dist<bd){ bd=dist; best=e; }
    }
    if(best && bd<THRESHOLD){
      matched=best; cam.className='cam ok';
      document.getElementById('hst').textContent = best.name;
      document.getElementById('hsc').textContent = 'ตรง ' + (100-bd*100).toFixed(0) + '%';
    }else{
      matched=null; cam.className='cam bad';
      document.getElementById('hst').textContent = EMP.length ? 'ไม่ตรงกับใคร' : 'ยังไม่มีใครลงทะเบียน';
      document.getElementById('hsc').textContent='';
    }
    gate();
  }, 500);
}

/* No project, no punch.
   An hour with no project silently becomes overhead. A year of that and every
   gross margin you report is fiction — and you cannot price the next bid. */
function gate(){
  const ok = !!matched && !!document.getElementById('proj').value;
  document.getElementById('bIn').disabled = !ok;
  document.getElementById('bOut').disabled = !ok;
  document.getElementById('proj').classList.toggle('need', !document.getElementById('proj').value);
}

function doPunch(type){
  const e=matched, p=PROJECTS.find(x=>x.id===document.getElementById('proj').value);
  if(!e||!p) return;
  const now=new Date(), open=isOpen(e);
  if(type==='in'&&open)   return toast('no',`${e.name} ลงเวลาเข้างานแล้ว — ยังไม่ได้ลงเวลาออก`);
  if(type==='out'&&!open) return toast('no',`${e.name} ยังไม่ได้ลงเวลาเข้างานวันนี้`);
  const go = gps => {
    e.punches.push({date:dstr(now), time:tstr(now), min:now.getHours()*60+now.getMinutes(),
      type, projectId:p.id, projectName:p.name, gps,
      /* No GPS is a FLAG, never a rejection. A man in a steel structure whose
         phone cannot see a satellite must not lose a day's pay to physics. */
      flags: gps?[]:['ไม่มีพิกัด GPS']});
    const d=todayOf(e), late=d?.late?` · สาย ${d.late} นาที`:'';
    toast('ok',`${type==='in'?'เข้างาน':'ออกงาน'} — ${e.name} · ${p.name} · ${tstr(now)}${late}`);
    save(); all();
  };
  navigator.geolocation
    ? navigator.geolocation.getCurrentPosition(
        pos=>go({lat:pos.coords.latitude,lng:pos.coords.longitude,acc:pos.coords.accuracy}),
        ()=>go(null), {enableHighAccuracy:true,timeout:8000})
    : go(null);
}

/* ── Registration: name + code + face. That is the entire record. ── */
function rgate(){
  const ok = document.getElementById('rcode').value.trim() && document.getElementById('rname').value.trim();
  document.getElementById('bRcam').disabled = !ok;
  document.getElementById('rcode').classList.toggle('need', !document.getElementById('rcode').value.trim());
  document.getElementById('rname').classList.toggle('need', !document.getElementById('rname').value.trim());
}
async function regLoop(){
  const v=document.getElementById('rvid'), cam=document.getElementById('rcam');
  clearInterval(loop);
  loop = setInterval(async ()=>{
    if(!v.videoWidth) return;
    const d = await faceapi.detectSingleFace(v, new faceapi.TinyFaceDetectorOptions({inputSize:320}))
      .withFaceLandmarks().withFaceDescriptor();
    pending = d||null;
    cam.className = 'cam ' + (d?'ok':'bad');
    document.getElementById('rhst').textContent = d?'พร้อมถ่าย':'ไม่พบใบหน้า';
    document.getElementById('bShot').disabled = !d;
  }, 400);
}
function shotReset(){
  shots=[];
  [0,1,2].forEach(i=>{ const s=document.getElementById('s'+i); s.className='shot';
    s.innerHTML=`<span>${['หน้าตรง','เอียงซ้าย','เอียงขวา'][i]}</span>`; });
  document.getElementById('bShot').textContent='ถ่ายภาพ (0/3)';
}
function capture(){
  if(!pending) return;
  const i=shots.length, v=document.getElementById('rvid');
  const c=document.createElement('canvas'); c.width=120; c.height=120;
  c.getContext('2d').drawImage(v,0,0,120,120);
  shots.push(Array.from(pending.descriptor));
  const s=document.getElementById('s'+i);
  s.className='shot done';
  s.innerHTML=`<img src="${c.toDataURL('image/jpeg',.7)}"><span class="lb">${['หน้าตรง','เอียงซ้าย','เอียงขวา'][i]}</span>`;
  document.getElementById('bShot').textContent=`ถ่ายภาพ (${shots.length}/3)`;
  if(shots.length===3) finish();
}
function finish(){
  const code=document.getElementById('rcode').value.trim(),
        name=document.getElementById('rname').value.trim(),
        pos =document.getElementById('rpos').value.trim()||'—',
        kind=document.getElementById('rkind').value;

  if(EMP.some(e=>e.code===code)) { toast('no','รหัสนี้มีอยู่แล้ว','r'); return shotReset(); }

  /* His own three samples must resemble each other. If they do not, the camera
     saw two different people — which happens when a colleague leans in to
     "help", and it poisons that man's record for as long as he works here. */
  let worst=0;
  for(let a=0;a<3;a++) for(let b=a+1;b<3;b++)
    worst=Math.max(worst, faceapi.euclideanDistance(shots[a],shots[b]));
  if(worst>0.55){ toast('no','ภาพ 3 ใบไม่เหมือนกันพอ — อาจมีคนอื่นเข้ามาในกรอบ ลองใหม่','r'); return shotReset(); }

  /* And he must not already be enrolled under another name. */
  for(const o of EMP) for(const f of o.face)
    if(faceapi.euclideanDistance(shots[0],f) < THRESHOLD){
      toast('no',`ใบหน้านี้ตรงกับ ${o.name} (${o.code}) ที่ลงทะเบียนแล้ว`,'r'); return shotReset(); }

  EMP.push({ code, name, pos,
    cls: kind==='overhead'?'overhead':'direct',
    exempt: kind==='exempt',
    face: shots.slice(), punches: [] });

  toast('ok',`ลงทะเบียน ${name} สำเร็จ`,'r');
  ['rcode','rname','rpos'].forEach(k=>document.getElementById(k).value='');
  rgate(); shotReset(); save(); all();
}
function delEmp(code){
  if(!confirm('ลบพนักงานคนนี้และประวัติการลงเวลาทั้งหมด?')) return;
  EMP = EMP.filter(e=>e.code!==code); save(); all(); closeD();
}

function toast(k,m,w){
  const t=document.getElementById(w==='r'?'rtoast':'toast');
  t.className='toast '+(k==='ok'?'ok':'no'); t.textContent=m;
  clearTimeout(window['_'+(w||'c')]);
  window['_'+(w||'c')]=setTimeout(()=>t.className='toast',7000);
}

/* ── Attendance maths — identical to the backend engine ── */
function days(e){
  const by={}; e.punches.forEach(p=>(by[p.date]??=[]).push(p));
  return Object.entries(by).map(([date,ps])=>{
    ps.sort((a,b)=>a.min-b.min);
    const i=ps.find(p=>p.type==='in'), o=[...ps].reverse().find(p=>p.type==='out');
    const proj=i?.projectName||o?.projectName||'—';
    if(!i||!o) return {date,incomplete:true,worked:0,late:0,ot:0,in:i||null,out:o||null,proj};

    /* The break is deducted even when nobody punched it. He ate. Everybody eats.
       Not deducting it pays 60 minutes a day, per man, for nothing — and once
       the crew works that out, nobody ever punches lunch again. */
    const worked=Math.max(0, o.min-i.min-SCH.brk);

    /* Lateness is measured from 08:00, not from the end of the grace window.
       Grace forgives lateness; it does not move the clock. */
    const late = i.min > SCH.start+SCH.grace ? i.min-SCH.start : 0;

    /* OT is EVIDENCE, never payment. Payroll pays APPROVED OT claims.
       Rounded DOWN — rounding up is a decision about the company's money and
       belongs to a human, not to Math.round(). */
    let ot=Math.max(0, worked-SCH.std);
    ot = ot<30 ? 0 : Math.floor(ot/30)*30;
    return {date,incomplete:false,worked,late,ot,in:i,out:o,proj};
  }).sort((a,b)=>b.date.localeCompare(a.date));
}
const todayOf=e=>days(e).find(d=>d.date===dstr(new Date()));
const isOpen=e=>{ const p=e.punches.filter(x=>x.date===dstr(new Date()));
  return p.length && p[p.length-1].type==='in'; };

/* ── Views ── */
function board(){
  document.getElementById('today').textContent =
    new Date().toLocaleDateString('th-TH',{weekday:'long',day:'numeric',month:'long'});
  let nIn=0,nLate=0,nNone=0;
  document.getElementById('board').innerHTML = EMP.length ? EMP.map(e=>{
    const d=todayOf(e); let cls='',st='ยังไม่ลงเวลา';
    if(d&&d.in&&!d.out){ cls=d.late?'late':'in'; nIn++; if(d.late)nLate++;
      st=`เข้า ${d.in.time} · ${d.proj}`+(d.late?` · สาย ${d.late}น.`:''); }
    else if(d&&d.in&&d.out){ cls='out'; nIn++; if(d.late)nLate++;
      st=`${d.in.time}–${d.out.time} · ${(d.worked/60).toFixed(1)} ชม.`; }
    else nNone++;
    return `<div class="pcell ${cls}" onclick="openEmp('${e.code}')">
      <div class="nm">${e.name}</div><div class="st">${st}</div></div>`;
  }).join('') : '<div style="padding:40px;text-align:center;color:var(--ink-3);grid-column:1/-1">ยังไม่มีพนักงาน — ไปที่แท็บ “ลงทะเบียน”</div>';
  document.getElementById('k-in').textContent=nIn;
  document.getElementById('k-late').textContent=nLate;
  document.getElementById('k-none').textContent=nNone;
}

function rlist(){
  document.getElementById('k-reg').textContent = EMP.length;
  document.getElementById('rlist').innerHTML = EMP.length ? EMP.map(e=>`<tr>
    <td class="mono">${e.code}</td><td><b>${e.name}</b></td>
    <td style="color:var(--ink-3)">${e.pos}</td>
    <td><span class="chip ${e.exempt?'i':e.cls==='overhead'?'a':'g'}">${
      e.exempt?'ผู้บริหาร':e.cls==='overhead'?'แบ็คออฟฟิศ':'หน้างาน'}</span></td>
    <td><button class="btn rd" style="padding:6px 12px;min-height:34px;font-size:12px"
      onclick="delEmp('${e.code}')">ลบ</button></td></tr>`).join('')
    : '<tr><td colspan="5" style="text-align:center;padding:36px;color:var(--ink-3)">ยังไม่มีใครลงทะเบียน</td></tr>';
  document.getElementById('proj').innerHTML='<option value="">— เลือกโครงการ —</option>'+
    PROJECTS.map(p=>`<option value="${p.id}">${p.code} — ${p.name}</option>`).join('');
}

function grid(){
  const T=EMP.length||1;
  const ring=(n,c)=>{const r=25,C=2*Math.PI*r,p=n/T;
    return `<div class="ring2"><svg width="58" height="58" viewBox="0 0 58 58">
      <circle cx="29" cy="29" r="${r}" fill="none" stroke="#EDF4F6" stroke-width="6"/>
      <circle cx="29" cy="29" r="${r}" fill="none" stroke="${c}" stroke-width="6" stroke-linecap="round"
        stroke-dasharray="${C}" stroke-dashoffset="${C*(1-p)}"/></svg><b>${n}</b></div>`;};

  document.getElementById('grid').innerHTML = PROJECTS.map(p=>{
    const people = EMP.filter(e=>e.punches.some(x=>x.projectId===p.id));
    let mins=0;
    EMP.forEach(e=>days(e).forEach(d=>{ if(d.in?.projectId===p.id) mins+=d.worked; }));
    const bo = p.kind==='overhead';
    return `<button class="card ${bo?'bo':''}" onclick="openProject('${p.id}')">
      <div class="code">${p.code}</div><h3>${p.name}</h3>
      <div class="cl">${bo?'ชั่วโมงรวมกับทีมบัญชี — ค่าดำเนินงาน':'ต้นทุนโครงการ'}</div>
      <div class="foot">${ring(people.length, bo?'#5B4FE9':'#22BFD3')}
        <div class="hrs"><span>ชั่วโมงรวม</span><b>${(mins/60).toFixed(1)}</b></div></div>
    </button>`;
  }).join('');
}

function timesheet(){
  document.getElementById('ts').innerHTML = EMP.length ? EMP.map(e=>{

function openProject(id){
  const p=PROJECTS.find(x=>x.id===id);
  const rows=[];
  EMP.forEach(e=>days(e).forEach(d=>{ if(d.in?.projectId===id) rows.push({e,d}); }));
  const mins=rows.reduce((s,r)=>s+r.d.worked,0);
  const people=[...new Set(rows.map(r=>r.e.code))].length;
  document.getElementById('drawer').innerHTML=`
    <div class="dh"><div><h2>${p.name}</h2><div class="m">${p.code}</div></div>
      <button class="x" onclick="closeD()">×</button></div>
    <div class="dstats">
      <div class="ds"><div class="k">พนักงาน</div><div class="v">${people}</div></div>
      <div class="ds"><div class="k">ชั่วโมงรวม</div><div class="v" style="color:var(--indigo)">${(mins/60).toFixed(1)}</div></div>
      <div class="ds"><div class="k">แมนเดย์</div><div class="v">${rows.length}</div></div>
    </div>
    <div class="db"><div class="panel"><h3>รายการลงเวลา</h3>
    ${rows.length?`<div class="tw"><table><thead><tr><th>วันที่</th><th>พนักงาน</th><th>เข้า</th><th>ออก</th>
      <th class="num">ชม.</th><th class="num">OT</th></tr></thead><tbody>
      ${rows.sort((a,b)=>b.d.date.localeCompare(a.d.date)).map(r=>`<tr>
        <td class="mono">${r.d.date}</td><td>${r.e.name}</td>
        <td class="mono">${r.d.in?.time||'—'}</td><td class="mono">${r.d.out?.time||'—'}</td>
        <td class="num">${(r.d.worked/60).toFixed(1)}</td>
        <td class="num" style="color:var(--indigo)">${r.d.ot?(r.d.ot/60).toFixed(1):'—'}</td>
      </tr>`).join('')}</tbody></table></div>`
      :'<div style="padding:36px;text-align:center;color:var(--ink-3)">ยังไม่มีใครลงเวลาในโครงการนี้</div>'}
    </div></div>`;
  openD();
}

function openD(){document.getElementById('drawer').classList.add('open');document.getElementById('scrim').classList.add('open');}
function closeD(){document.getElementById('drawer').classList.remove('open');document.getElementById('scrim').classList.remove('open');}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeD();});

function tab(t){
  ['c','r','p','t'].forEach(k=>{
    document.getElementById('v-'+k).classList.toggle('hide', k!==t);
    document.getElementById('t-'+k).setAttribute('aria-selected', k===t);
  });
  if(t!=='c'&&t!=='r'){ clearInterval(loop); stream?.getTracks().forEach(x=>x.stop()); stream=null; }
}
function all(){ board(); rlist(); grid(); timesheet(); }

setInterval(()=>{ const d=new Date();
  document.getElementById('clk').textContent=`${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`; },1000);

if(!window.isSecureContext) document.getElementById('ctx').classList.remove('hide');
load(); all();
if(!EMP.length) tab('r');
</script>
</body>
</html>

        :'<span class="chip">ยังไม่มีข้อมูล</span>'}</td></tr>`;
  }).join('') : '<tr><td colspan="7" style="text-align:center;padding:36px;color:var(--ink-3)">ยังไม่มีข้อมูล</td></tr>';
}


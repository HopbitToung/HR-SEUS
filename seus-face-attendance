/* A man's project membership is the project he most recently punched into.
   Nothing is invented: if he never punched, he is not in a project. */
function projOf(e){
  const last = e.punches[e.punches.length-1];
  return last ? last.projectId : null;
}
const inProj = id => EMP.filter(e=>projOf(e)===id);


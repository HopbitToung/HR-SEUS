    </div>
    <div class="db">${list.length?list.map(e=>`
      <div class="erow"><div><div class="nm">${e.name}${flags(e).length?'<span class="dot"></span>':''}</div>
        <div class="ps">${e.pos} · ${e.basis==='daily'?'รายวัน':'รายเดือน'}${e.exemptSso?' · ปกส.ยกเว้น ('+e.ssoReason+')':''}</div></div>

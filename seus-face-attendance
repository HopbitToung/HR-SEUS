/* ── Attendance maths — identical rules to the backend engine ── */
function days(e){
  const by={}; e.punches.forEach(p=>(by[p.date] ??= []).push(p));
  return Object.entries(by).map(([date,ps])=>{
    ps.sort((a,b)=>a.min-b.min);
    const i=ps.find(p=>p.type==='in'), o=[...ps].reverse().find(p=>p.type==='out');
    const proj = i?.projectName || o?.projectName || '—';
    if(!i||!o) return {date, incomplete:true, worked:0, late:0, ot:0, in:i||null, out:o||null, proj};

    /* The break is deducted even when nobody punched it. He ate. Everybody eats.
       Not deducting it pays 60 minutes a day, per man, for nothing -- and once
       the crew works that out, nobody ever punches lunch again. */
    const worked = Math.max(0, o.min - i.min - SCH.brk);

    /* Lateness is measured from 08:00, not from the end of the grace window.
       Grace forgives lateness; it does not move the clock. 08:20 with 15 min
       grace is 20 minutes late, not 5. */
    const late = i.min > SCH.start + SCH.grace ? i.min - SCH.start : 0;

    /* OT here is EVIDENCE, never payment. Payroll reads APPROVED OT claims.
       Rounded DOWN to 30-min blocks -- rounding up is a decision about the
       company's money and belongs to a human, not to Math.round(). */
    let ot = Math.max(0, worked - SCH.std);
    ot = ot < 30 ? 0 : Math.floor(ot/30)*30;
    return {date, incomplete:false, worked, late, ot, in:i, out:o, proj};
  }).sort((a,b)=>b.date.localeCompare(a.date));
}
const todayOf = e => days(e).find(d=>d.date===dstr(new Date()));
const isOpen = e => { const p=e.punches.filter(x=>x.date===dstr(new Date()));
  return p.length && p[p.length-1].type==='in'; };

function recalc(e){
  e.alwTotal = Object.values(e.alw).reduce((a,b)=>a+b,0);
  e.gross = (e.basis==='daily'? e.base*26 : e.base) + e.alwTotal;
  /* Both sides of SSO honour the exemption. Zeroing only the employee's
     deduction while still accruing the employer's 5% inflates project cost for
     ever -- and nobody audits a number that only ever grows. */
  e.sso = e.exemptSso ? 0 : Math.min(Math.max(Math.min(e.gross,15000),1650)*0.05, 750);
  e.ssoEmployer = e.sso;
  e.tax = annualTax(e.gross*12, e.children||0, !!e.spouse)/12;
  e.net = e.gross - e.sso - e.tax;
}
function annualTax(g, ch, sp){
  const BR=[[0,150000,0],[150000,300000,5],[300000,500000,10],[500000,750000,15],
            [750000,1000000,20],[1000000,2000000,25],[2000000,5000000,30],[5000000,null,35]];
  const allow = 60000 + (sp?60000:0) + 30000*Math.min(ch,3);
  let t = Math.max(0, g - Math.min(g*0.5,100000) - allow), tax=0;
  for(const [lo,hi,r] of BR){ if(t<=lo) break; tax += ((hi===null?t:Math.min(t,hi))-lo)*r/100; }
  return tax;
}


<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>SEUS — ระบบลงเวลาด้วยใบหน้า</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api@1.7.15/dist/face-api.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<style>
:root{
  --cyan:#22BFD3; --cyan-d:#16A8BC; --cyan-l:#E4F7FA;
  --indigo:#5B4FE9; --indigo-l:#ECEAFE;
  --amber:#F6B43C; --amber-l:#FEF3E0;
  --rose:#EF6B6B; --rose-l:#FDECEC;
  --green:#3CC28A; --green-l:#E4F7EF;
  --bg:#E9F6FA; --ink:#2E3B44; --ink-2:#5E7079; --ink-3:#9AAAB3;
  --line:#E6EFF2; --sh:0 1px 3px rgba(46,59,68,.06),0 6px 20px rgba(46,59,68,.05); --r:14px;
}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--ink);font-family:'IBM Plex Sans Thai',system-ui,sans-serif;
  font-size:14.5px;line-height:1.55;-webkit-font-smoothing:antialiased}
.mono{font-family:'IBM Plex Mono',monospace;font-variant-numeric:tabular-nums}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input,select{font-family:inherit}
.hide{display:none!important}

.hero{background:var(--cyan);color:#fff;border-radius:var(--r);margin:16px 20px 0;padding:20px 26px;
  display:flex;align-items:center;gap:18px;box-shadow:var(--sh)}
.hero h1{font-size:25px;font-weight:700}
.hero .sub{font-size:12.5px;opacity:.9;margin-top:2px}
.hero .badge{margin-left:auto;text-align:right}
.hero .badge b{display:block;font-size:14px}
.hero .badge span{font-size:11px;opacity:.85}

nav{display:flex;gap:6px;padding:14px 20px 0;overflow-x:auto;scrollbar-width:none}
nav::-webkit-scrollbar{display:none}
nav button{padding:9px 17px;border-radius:999px;font-size:13.5px;font-weight:500;background:#fff;
  color:var(--ink-2);box-shadow:var(--sh);white-space:nowrap;min-height:42px}
nav button[aria-selected=true]{background:var(--indigo);color:#fff;font-weight:600}
nav .sp{margin-left:auto;display:flex;gap:8px}
.btn{padding:9px 16px;border-radius:999px;font-size:13px;font-weight:600;background:#fff;
  color:var(--ink-2);box-shadow:var(--sh);white-space:nowrap;min-height:42px}
.btn.go{background:var(--indigo);color:#fff} .btn.cy{background:var(--cyan);color:#fff}
.btn:disabled{opacity:.45;cursor:not-allowed}
main{padding:16px 20px 80px;max-width:1440px;margin:0 auto}

.head{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:16px;flex-wrap:wrap}
.head h2{font-size:21px;font-weight:600}
.head p{color:var(--ink-3);font-size:13px}
.kpis{display:flex;gap:10px;flex-wrap:wrap}
.kpi{background:#fff;border-radius:var(--r);box-shadow:var(--sh);padding:12px 16px;min-width:118px}
.kpi .k{font-size:11px;color:var(--ink-3)}
.kpi .v{font-family:'IBM Plex Mono';font-size:21px;font-weight:600}
.kpi.cy .v{color:var(--cyan-d)} .kpi.in .v{color:var(--indigo)}
.kpi.am .v{color:#B67B12} .kpi.ro .v{color:var(--rose)} .kpi.gr .v{color:#2A9169}

.panel{background:#fff;border-radius:var(--r);box-shadow:var(--sh);overflow:hidden;margin-bottom:16px}
.panel h3{padding:14px 20px;font-size:15px;font-weight:600;border-bottom:1px solid var(--line);
  display:flex;align-items:center;gap:10px}
.panel .in{padding:20px}
.tw{overflow-x:auto} .tw table{min-width:600px}
table{width:100%;border-collapse:collapse;font-size:13.5px}
th{text-align:left;padding:11px 16px;font-size:11px;text-transform:uppercase;letter-spacing:.05em;
  color:var(--ink-3);border-bottom:1px solid var(--line);font-weight:600;background:#F7FBFC}
td{padding:11px 16px;border-bottom:1px solid var(--line)}
tr:last-child td{border:none}
td.num,th.num{text-align:right;font-family:'IBM Plex Mono'}
.chip{font-size:11px;padding:3px 9px;border-radius:999px;background:var(--cyan-l);color:var(--cyan-d);font-weight:500;white-space:nowrap}
.chip.i{background:var(--indigo-l);color:var(--indigo)} .chip.a{background:var(--amber-l);color:#B67B12}
.chip.r{background:var(--rose-l);color:#C94545} .chip.g{background:var(--green-l);color:#2A9169}

/* ── secure-context banner ── */
.ctx{display:flex;gap:12px;background:var(--rose-l);border-radius:var(--r);padding:15px 18px;margin-bottom:16px;align-items:flex-start}
.ctx b{color:#C94545}
.ctx p{font-size:13px;color:var(--ink-2);margin-top:3px}
.ctx code{font-family:'IBM Plex Mono';font-size:12px;background:#fff;padding:1px 6px;border-radius:5px}

/* ── camera ── */
.cam{position:relative;background:#0E2027;border-radius:12px;overflow:hidden;aspect-ratio:4/3;
  display:grid;place-items:center}
.cam video{width:100%;height:100%;object-fit:cover;transform:scaleX(-1)}
.cam canvas{position:absolute;inset:0;width:100%;height:100%;transform:scaleX(-1)}
.cam .ph{color:#7FA3AE;font-size:13.5px;text-align:center;padding:24px}
.cam .ring{position:absolute;inset:8%;border:3px dashed rgba(255,255,255,.35);border-radius:50%;pointer-events:none}
.cam.ok .ring{border-color:var(--green);border-style:solid}
.cam.bad .ring{border-color:var(--amber)}
.cam .hud{position:absolute;left:0;right:0;bottom:0;padding:11px 14px;background:linear-gradient(transparent,rgba(0,0,0,.65));
  color:#fff;font-size:13px;display:flex;justify-content:space-between;align-items:center;gap:10px}
.cam .hud .st{font-weight:600}
.shots{display:flex;gap:8px;margin-top:12px}
.shot{flex:1;aspect-ratio:1;border-radius:10px;border:2px dashed #CBDDE3;display:grid;place-items:center;
  font-size:11.5px;color:var(--ink-3);overflow:hidden;position:relative;background:#F7FBFC}
.shot img{width:100%;height:100%;object-fit:cover;transform:scaleX(-1)}
.shot.done{border:2px solid var(--green)}
.shot .lb{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.55);color:#fff;font-size:10px;padding:2px}

label.fl{display:block;font-size:12px;color:var(--ink-3);margin-bottom:5px}
select,input.tx{width:100%;padding:12px 13px;border-radius:10px;border:1.5px solid var(--line);
  background:#FBFDFE;font-size:15px;color:var(--ink);min-height:48px}
select:focus,input.tx:focus{outline:none;border-color:var(--cyan)}
select.need{border-color:var(--rose);background:#FFF7F7}
.cibtns{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:14px}
.cibtn{padding:18px;border-radius:12px;font-size:16px;font-weight:700;color:#fff;min-height:60px}
.cibtn.i{background:var(--green)} .cibtn.o{background:var(--rose)}
.cibtn:disabled{opacity:.4;cursor:not-allowed}
.toast{margin-top:12px;padding:13px 15px;border-radius:10px;font-size:13.5px;display:none}
.toast.ok{display:block;background:var(--green-l);color:#2A9169}
.toast.no{display:block;background:var(--rose-l);color:#C94545}
.toast.wa{display:block;background:var(--amber-l);color:#B67B12}

.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.g3{display:grid;grid-template-columns:420px 1fr;gap:16px}
@media(max-width:960px){.g2,.g3{grid-template-columns:1fr}}

.cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px}
.card{background:#fff;border-radius:var(--r);box-shadow:var(--sh);padding:19px 20px;text-align:left;
  width:100%;transition:transform .18s,box-shadow .18s;cursor:pointer}
.card:hover{transform:translateY(-3px);box-shadow:0 4px 10px rgba(46,59,68,.08),0 14px 34px rgba(46,59,68,.09)}
.card .code{font-family:'IBM Plex Mono';font-size:11px;color:var(--cyan-d);font-weight:600}
.card h3{font-size:17px;font-weight:600;margin:4px 0 2px;padding:0;border:none}
.card .client{font-size:12.5px;color:var(--ink-3);min-height:19px}
.card .foot{display:flex;align-items:center;justify-content:space-between;margin-top:16px;gap:12px}
.ring2{width:58px;height:58px;position:relative;flex-shrink:0}
.ring2 svg{transform:rotate(-90deg)}
.ring2 b{position:absolute;inset:0;display:grid;place-items:center;font-family:'IBM Plex Mono';font-size:17px;font-weight:600}
.card .cost b{font-family:'IBM Plex Mono';font-size:16px;color:var(--indigo);font-weight:600}
.card .cost span{display:block;font-size:10.5px;color:var(--ink-3);text-align:right}
.card .roles{margin-top:13px;padding-top:11px;border-top:1px solid var(--line);display:flex;gap:5px;flex-wrap:wrap}
.card.bo{border:2px solid var(--indigo)}

.board{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:9px;padding:16px}
.pcell{border:1.5px solid var(--line);border-radius:12px;padding:12px 13px;cursor:pointer;min-height:70px}
.pcell:hover{border-color:var(--cyan)}
.pcell .nm{font-size:13px;font-weight:500;line-height:1.3}
.pcell .st{font-family:'IBM Plex Mono';font-size:11px;margin-top:4px;color:var(--ink-3)}
.pcell.in{background:var(--green-l);border-color:#BFE9D6} .pcell.in .st{color:#2A9169}
.pcell.out{background:var(--cyan-l);border-color:#C4EBF1} .pcell.out .st{color:var(--cyan-d)}
.pcell.late{background:var(--amber-l);border-color:#F6DFB4} .pcell.late .st{color:#B67B12}
.pcell.nokyc{border-color:#F3C9C9;background:#FEF6F6}
.pcell.nokyc .st{color:#C94545}
.pcell.exempt{opacity:.6}

.scrim{position:fixed;inset:0;background:rgba(30,45,52,.45);opacity:0;pointer-events:none;transition:.22s;z-index:40}
.scrim.open{opacity:1;pointer-events:auto}
.drawer{position:fixed;top:0;right:0;bottom:0;width:min(900px,100%);z-index:50;background:var(--bg);
  transform:translateX(100%);transition:transform .3s cubic-bezier(.2,.8,.2,1);display:flex;flex-direction:column;
  box-shadow:-8px 0 40px rgba(30,45,52,.2)}
.drawer.open{transform:none}
.dh{background:var(--cyan);color:#fff;padding:20px 24px;display:flex;align-items:flex-start;gap:14px}
.dh h2{font-size:21px} .dh .m{font-size:12.5px;opacity:.9;margin-top:2px}
.dh .x{margin-left:auto;font-size:26px;padding:0 8px}
.dstats{display:flex;background:#fff;overflow-x:auto}
.ds{flex:1;min-width:112px;padding:13px 18px;border-right:1px solid var(--line)}
.ds:last-child{border:none}
.ds .k{font-size:10.5px;color:var(--ink-3)}
.ds .v{font-family:'IBM Plex Mono';font-size:18px;font-weight:600}
.db{flex:1;overflow-y:auto;padding:14px}
.erow{display:flex;gap:12px;align-items:center;background:#fff;border-radius:12px;padding:13px 15px;
  margin-bottom:8px;box-shadow:var(--sh);flex-wrap:wrap}
.erow .nm{font-weight:600;font-size:14px}
.erow .ps{font-size:12px;color:var(--ink-3)}
.erow .rt{margin-left:auto;text-align:right;font-family:'IBM Plex Mono';font-size:14px;font-weight:600;color:var(--indigo)}
.erow .rt small{display:block;font-family:'IBM Plex Sans Thai';font-size:10.5px;color:var(--ink-3);font-weight:400}
.mini{font-size:12px;padding:8px 12px;border-radius:999px;background:#F2F7F9;color:var(--ink-2);font-weight:500;min-height:38px}
.mini:hover{background:var(--indigo-l);color:var(--indigo)}
.dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--rose);margin-left:5px}
.edit{background:#fff;border-radius:12px;padding:17px;margin-bottom:9px;box-shadow:var(--sh)}
.fg{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:11px}
.f label{display:block;font-size:11px;color:var(--ink-3);margin-bottom:4px}
.f input,.f select{width:100%;padding:10px 11px;border-radius:9px;border:1.5px solid var(--line);
  background:#FBFDFE;font-size:13.5px;min-height:42px}
.f.req input:placeholder-shown{border-color:var(--rose)}
.ef{display:flex;gap:9px;margin-top:14px;flex-wrap:wrap}

.drop{border:2.5px dashed #C3DBE3;border-radius:var(--r);padding:36px 20px;text-align:center;
  background:#F7FBFC;cursor:pointer;transition:.16s}
.drop:hover,.drop.over{border-color:var(--cyan);background:var(--cyan-l)}
.drop b{display:block;font-size:16px;margin-bottom:4px}
.drop span{font-size:13px;color:var(--ink-3)}
.blk{display:flex;gap:11px;padding:13px 18px;border-bottom:1px solid var(--line);align-items:flex-start}
.blk:last-child{border:none}
.sev{font-family:'IBM Plex Mono';font-size:10px;font-weight:700;padding:3px 8px;border-radius:6px;flex-shrink:0;margin-top:2px}
.sev.block{background:var(--rose-l);color:#C94545}
.sev.warn{background:var(--amber-l);color:#B67B12}
.sev.ok{background:var(--green-l);color:#2A9169}
.blk h5{font-size:14px;font-weight:600}
.blk p{font-size:12.5px;color:var(--ink-3);margin-top:2px;max-width:84ch}

@media(max-width:760px){
  .hero{margin:12px 12px 0;padding:16px;flex-wrap:wrap}
  .hero h1{font-size:20px} .hero .badge{margin-left:0}
  nav{padding:12px 12px 0} main{padding:14px 12px 70px}
  .cards{grid-template-columns:1fr} .board{grid-template-columns:1fr 1fr}
  .drawer{width:100%} .fg{grid-template-columns:1fr 1fr}
  .kpi{flex:1;min-width:0}
}
@media(max-width:400px){.fg,.board{grid-template-columns:1fr}}
@media(prefers-reduced-motion:reduce){*{transition:none!important}}
</style>
</head>
<body>

<div class="hero">
  <div><h1>ระบบลงเวลาด้วยใบหน้า</h1><div class="sub">SEUS Engineering Co., Ltd.</div></div>
  <div class="badge"><b>SEUS</b><span>Electrical &amp; Instrumentation</span></div>
</div>

<nav>
  <button id="t-c" aria-selected="true" onclick="tab('c')">ลงเวลา</button>
  <button id="t-k" aria-selected="false" onclick="tab('k')">ลงทะเบียนใบหน้า</button>
  <button id="t-p" aria-selected="false" onclick="tab('p')">โครงการ</button>
  <button id="t-t" aria-selected="false" onclick="tab('t')">ตารางเวลา</button>
  <button id="t-i" aria-selected="false" onclick="tab('i')">นำเข้าข้อมูล</button>
  <button id="t-s" aria-selected="false" onclick="tab('s')">สรุป HR / บัญชี</button>
  <div class="sp"><button class="btn" onclick="save()">บันทึก</button></div>
</nav>

<main>
<div class="ctx hide" id="ctx">
  <span class="sev block">HTTPS</span>
  <div><b>เปิดจากไฟล์ในเครื่อง — กล้องและ GPS ใช้ไม่ได้</b>
    <p>เบราว์เซอร์อนุญาตให้ใช้กล้องและพิกัดเฉพาะเมื่อเปิดผ่าน <code>https://</code> หรือ <code>localhost</code> เท่านั้น (secure context)<br>
    ต้องอัปไฟล์นี้ขึ้น GitHub Pages หรือเซิร์ฟเวอร์ที่มี SSL ก่อน ระบบใบหน้าจึงจะทำงาน — <b>นี่เป็นกฎความปลอดภัยของเบราว์เซอร์ ไม่ใช่ข้อจำกัดของระบบ</b></p></div>
</div>

<!-- ══ CHECK IN ══ -->
<div id="v-c">
  <div class="head">
    <div><h2>ลงเวลาด้วยใบหน้า</h2><p>เลือกโครงการ → มองกล้อง → ระบบจะจำได้เอง</p></div>
    <div class="kpis">
      <div class="kpi gr"><div class="k">เข้างานแล้ว</div><div class="v" id="k-in">0</div></div>
      <div class="kpi am"><div class="k">มาสาย</div><div class="v" id="k-late">0</div></div>
      <div class="kpi ro"><div class="k">ยังไม่ลงเวลา</div><div class="v" id="k-none">0</div></div>
      <div class="kpi in"><div class="k">ลงทะเบียนใบหน้าแล้ว</div><div class="v" id="k-kyc">0</div></div>
    </div>
  </div>

  <div class="g3">
    <div class="panel">
      <h3>ลงเวลา <span class="chip" id="clk">--:--:--</span></h3>
      <div class="in">
        <label class="fl">โครงการ <b style="color:var(--rose)">*</b> — ต้องเลือกทุกครั้ง</label>
        <select id="proj" class="need" onchange="projPicked()"></select>

        <div class="cam" id="cam" style="margin-top:14px">
          <video id="vid" autoplay muted playsinline></video>
          <canvas id="ov"></canvas>
          <div class="ring"></div>
          <div class="ph" id="camph">กดปุ่มด้านล่างเพื่อเปิดกล้อง</div>
          <div class="hud hide" id="hud"><span class="st" id="hudst">กำลังค้นหาใบหน้า…</span><span class="mono" id="hudsc"></span></div>
        </div>

        <div class="cibtns">
          <button class="cibtn i" id="bIn" onclick="doPunch('in')" disabled>เข้างาน</button>
          <button class="cibtn o" id="bOut" onclick="doPunch('out')" disabled>ออกงาน</button>
        </div>
        <button class="btn cy" style="width:100%;margin-top:10px;min-height:46px" id="bCam" onclick="startCam('c')">เปิดกล้อง</button>
        <div class="toast" id="toast"></div>
      </div>
    </div>

    <div class="panel">
      <h3>สถานะวันนี้ <span style="font-weight:400;color:var(--ink-3);font-size:13px" id="today"></span></h3>
      <div class="board" id="board"></div>
    </div>
  </div>
</div>

<!-- ══ KYC ══ -->
<div id="v-k" class="hide">
  <div class="head">
    <div><h2>ลงทะเบียนใบหน้า (KYC)</h2><p>เก็บ 3 มุม · ใบหน้าถูกแปลงเป็นเวกเตอร์ 128 ตัวเลข ไม่ได้เก็บรูปเป็นใบหน้า</p></div>
    <div class="kpis">
      <div class="kpi gr"><div class="k">ลงทะเบียนแล้ว</div><div class="v" id="k-done">0</div></div>
      <div class="kpi ro"><div class="k">ยังไม่ลงทะเบียน</div><div class="v" id="k-todo">0</div></div>
    </div>
  </div>

  <div class="g2">
    <div class="panel">
      <h3>ลงทะเบียน</h3>
      <div class="in">
        <label class="fl">พนักงาน</label>
        <select id="kwho" onchange="kycReset()"></select>
        <div class="cam" id="kcam" style="margin-top:14px">
          <video id="kvid" autoplay muted playsinline></video>
          <div class="ring"></div>
          <div class="ph" id="kcamph">กดเปิดกล้องเพื่อเริ่ม</div>
          <div class="hud hide" id="khud"><span class="st" id="khudst">—</span></div>
        </div>
        <div class="shots">
          <div class="shot" id="s0"><span>หน้าตรง</span></div>
          <div class="shot" id="s1"><span>เอียงซ้าย</span></div>
          <div class="shot" id="s2"><span>เอียงขวา</span></div>
        </div>
        <div class="cibtns" style="grid-template-columns:1fr">
          <button class="cibtn i" id="bShot" onclick="capture()" disabled>ถ่ายภาพ (0/3)</button>
        </div>
        <button class="btn cy" style="width:100%;margin-top:10px;min-height:46px" onclick="startCam('k')">เปิดกล้อง</button>
        <div class="toast" id="ktoast"></div>
      </div>
    </div>

    <div class="panel">
      <h3>สถานะการลงทะเบียน</h3>
      <div class="tw"><table>
        <thead><tr><th>พนักงาน</th><th>ตำแหน่ง</th><th>สถานะ</th></tr></thead>
        <tbody id="kyclist"></tbody>
      </table></div>
    </div>
  </div>
</div>

<!-- ══ PROJECTS ══ -->
<div id="v-p" class="hide">

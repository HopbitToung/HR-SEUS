/* ── 1:N identification ── */
async function detectLoop(){
  const v=document.getElementById('vid'), cam=document.getElementById('cam');
  clearInterval(detLoop);
  detLoop = setInterval(async ()=>{
    if(!v.videoWidth) return;
    const d = await faceapi.detectSingleFace(v, new faceapi.TinyFaceDetectorOptions({inputSize:320}))
      .withFaceLandmarks().withFaceDescriptor();

    if(!d){ matched=null; cam.className='cam bad';
      document.getElementById('hudst').textContent='ไม่พบใบหน้า — มองตรงกล้อง';
      document.getElementById('hudsc').textContent=''; gate(); return; }

    let best=null, bd=99;
    for(const e of enrolled()){
      for(const f of e.face){
        const dist = faceapi.euclideanDistance(d.descriptor, f);
        if(dist<bd){ bd=dist; best=e; }
      }
    }

    if(best && bd < MATCH_THRESHOLD){
      matched = best; cam.className='cam ok';
      document.getElementById('hudst').textContent = best.name;
      document.getElementById('hudsc').textContent = 'ตรงกัน ' + (100-bd*100).toFixed(0) + '%';
    }else{
      matched=null; cam.className='cam bad';
      document.getElementById('hudst').textContent = enrolled().length
        ? 'ไม่พบใบหน้าที่ตรงกับใคร' : 'ยังไม่มีใครลงทะเบียนใบหน้า';
      document.getElementById('hudsc').textContent = best ? bd.toFixed(2) : '';
    }
    gate();
  }, 500);
}

/* The project gate. No project, no punch — for site staff.
   An unallocated hour becomes overhead silently, and a year of that makes every
   gross margin you report a work of fiction. */
function gate(){
  const p = document.getElementById('proj').value;
  const ok = !!matched && !!p;
  document.getElementById('bIn').disabled = !ok;
  document.getElementById('bOut').disabled = !ok;
}
function projPicked(){
  const s=document.getElementById('proj');
  s.classList.toggle('need', !s.value); gate();
}

function doPunch(type){
  const e = matched, pid = document.getElementById('proj').value;
  if(!e || !pid) return;
  const p = PROJECTS.find(x=>x.id===pid);
  const now = new Date();
  const open = isOpen(e);
  if(type==='in' && open)  return toast('no', `${e.name} ลงเวลาเข้างานแล้ว — ยังไม่ได้ลงเวลาออก`);
  if(type==='out' && !open) return toast('no', `${e.name} ยังไม่ได้ลงเวลาเข้างานวันนี้`);

  navigator.geolocation?.getCurrentPosition(
    pos => record(e,type,now,p,{lat:pos.coords.latitude,lng:pos.coords.longitude,acc:pos.coords.accuracy}),
    ()  => record(e,type,now,p,null),
    {enableHighAccuracy:true, timeout:8000}
  ) ?? record(e,type,now,p,null);
}

function record(e,type,now,p,gps){
  e.punches.push({date:dstr(now), time:tstr(now), min:now.getHours()*60+now.getMinutes(),
    type, projectId:p.id, projectName:p.name, gps,
    /* No GPS is a FLAG, never a rejection. A man inside a steel structure whose
       phone cannot see a satellite must not lose a day's pay to physics. */
    flags: gps?[]:['ไม่มีพิกัด GPS']});
  const d = todayOf(e);
  const late = d?.late ? ` · มาสาย ${d.late} นาที` : '';
  toast('ok', `${type==='in'?'เข้างาน':'ออกงาน'} — ${e.name} · ${p.name} · ${tstr(now)}${late}${gps?'':' · ไม่มีพิกัด (ตั้งธง)'}`);
  save(); board(); timesheet(); render(); summary();
}


function kycReset(){ kycShots=[]; [0,1,2].forEach(i=>{
  const s=document.getElementById('s'+i); s.className='shot';
  s.innerHTML=`<span>${['หน้าตรง','เอียงซ้าย','เอียงขวา'][i]}</span>`; });
  document.getElementById('bShot').textContent='ถ่ายภาพ (0/3)';
}
function capture(){
  if(!pending) return;
  const i = kycShots.length;
  const v = document.getElementById('kvid');
  const c = document.createElement('canvas');
  c.width=120; c.height=120;
  c.getContext('2d').drawImage(v,0,0,120,120);

  kycShots.push(Array.from(pending.descriptor));
  const s=document.getElementById('s'+i);
  s.className='shot done';
  s.innerHTML=`<img src="${c.toDataURL('image/jpeg',0.7)}"><span class="lb">${['หน้าตรง','เอียงซ้าย','เอียงขวา'][i]}</span>`;
  document.getElementById('bShot').textContent=`ถ่ายภาพ (${kycShots.length}/3)`;

  if(kycShots.length===3){
    const e = EMP.find(x=>x.id===document.getElementById('kwho').value);

    /* His own three samples must resemble each other. If they do not, the camera
       saw two different people -- which happens when a colleague "helps" during
       enrolment, and it poisons that man's face record for as long as he works here. */
    let worst=0;
    for(let a=0;a<3;a++) for(let b=a+1;b<3;b++)
      worst = Math.max(worst, faceapi.euclideanDistance(kycShots[a], kycShots[b]));
    if(worst > 0.55){
      toast('no','ภาพ 3 ใบไม่เหมือนกันพอ — อาจมีคนอื่นเข้ามาในกรอบ ลองใหม่','k');
      kycReset(); return;
    }

    /* And he must not already exist under another name. */
    for(const other of enrolled()){
      if(other.id===e.id) continue;
      for(const f of other.face){
        if(faceapi.euclideanDistance(kycShots[0], f) < MATCH_THRESHOLD){
          toast('no',`ใบหน้านี้ตรงกับ ${other.name} ที่ลงทะเบียนไว้แล้ว — ตรวจสอบก่อน`,'k');
          kycReset(); return;
        }
      }
    }

    e.face = kycShots.slice();
    toast('ok', `ลงทะเบียนใบหน้า ${e.name} สำเร็จ`, 'k');
    kycReset(); save(); kycList(); board(); render();
  }
}


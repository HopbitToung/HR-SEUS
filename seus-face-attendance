function saveEmp(id){
  const e=EMP.find(x=>x.id===id), g=k=>document.getElementById('q-'+k)?.value.trim()??'';
  e.code=g('code'); e.nid=g('nid'); e.bank=g('bank'); e.acc=g('acc');
  if(!e.exemptSso) e.ssoNo=g('sso');
  const ch=g('ch'); e.children = ch===''?null:parseInt(ch,10);
  e.spouse = g('sp')==='1'; e.base=+g('base')||0;
  e.alw={'ตำแหน่ง':+g('a1')||0,'ประสบการณ์':+g('a2')||0,'โทรศัพท์':+g('a3')||0,'น้ำมัน':+g('a4')||0};
  recalc(e); save(); render(); summary(); board(); timesheet();
  document.getElementById('host-'+id).innerHTML='';
}
function openD(){document.getElementById('drawer').classList.add('open');document.getElementById('scrim').classList.add('open');}
function closeD(){document.getElementById('drawer').classList.remove('open');document.getElementById('scrim').classList.remove('open');}

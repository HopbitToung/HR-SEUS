/* ── IMPORT: reads the register file you already use. No reformatting. ──
   The columns below are EXACTLY the ones in ประวัติพนักงาน.xlsx, sheet
   "Database", header on row 3. Nothing was renamed to suit the code -- the code
   was written to suit the file, because the file is what your HR actually keeps. */
const COLS = {
  code:'รหัสพนักงาน', prefix:'คำนำหน้า', first:'ชื่อ', last:'นามสกุล', nick:'ชื่อเล่น',
  pos:'ตำแหน่ง', nid:'เลขประจำตัวประชาชน', dob:'วันเกิด', sex:'เพศ', phone:'เบอร์โทร',
  hire:'วันที่เริ่มงาน', basis:'รายวัน\n/รายเดือน', freq:'การรับเงินเดือน',
  status:'สถานะการจ้าง', base:'ค่าแรง (ฐาน)',
  a1:'ค่าตำแหน่ง', a2:'ค่าประสบการณ์', a3:'ค่าโทรศัพท์', a4:'ค่าน้ำมัน',
};
let staged = null;

document.getElementById('file').onchange = e => e.target.files[0] && readFile(e.target.files[0]);
const drop = document.getElementById('drop');
['dragover','dragenter'].forEach(k=>drop.addEventListener(k,e=>{e.preventDefault();drop.classList.add('over');}));
['dragleave','drop'].forEach(k=>drop.addEventListener(k,e=>{e.preventDefault();drop.classList.remove('over');}));
drop.addEventListener('drop', e => e.dataTransfer.files[0] && readFile(e.dataTransfer.files[0]));

function nidOk(s){
  s = String(s||'').replace(/\D/g,'');
  if(s.length!==13) return false;
  let sum=0; for(let i=0;i<12;i++) sum += +s[i]*(13-i);
  return (11-(sum%11))%10 === +s[12];
}

function readFile(f){
  const r = new FileReader();
  r.onload = ev => {
    const wb = XLSX.read(ev.target.result, {type:'array'});
    const sh = wb.Sheets['Database'] || wb.Sheets[wb.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(sh, {range:2, defval:''});   // header row 3
    dryRun(rows.filter(r => r[COLS.first] || r[COLS.code]));
  };
  r.readAsArrayBuffer(f);
}

/* DRY RUN FIRST. ALWAYS.
   You will get a dirty sheet on the first attempt. Every company does.
   So: complain loudly here, and write nothing until a human has looked. */
function dryRun(rows){
  const ok=[], bad=[];
  rows.forEach((r,i)=>{
    const errs=[];
    const code = String(r[COLS.code]||'').trim();
    const name = `${r[COLS.prefix]||''}${r[COLS.first]||''} ${r[COLS.last]||''}`.trim();
    if(!code || code==='-') errs.push('ไม่มีรหัสพนักงาน — ระบบจะออกรหัสถัดไปให้');
    if(!nidOk(r[COLS.nid])) errs.push('เลขบัตรประชาชนไม่ผ่าน checksum 13 หลัก');
    const base = +String(r[COLS.base]).replace(/[^\d.]/g,'');
    if(!base) errs.push('ค่าแรงฐานไม่ใช่ตัวเลข');
    (errs.length?bad:ok).push({row:i+4, code, name, errs, raw:r, base});
  });
  staged = {ok, bad};

  const known = ok.filter(x=>EMP.some(e=>e.code===x.code)).length;
  document.getElementById('dryout').innerHTML = `
    <div class="blk"><span class="sev ok">READ</span><div>
      <h5>อ่านได้ ${rows.length} แถว · ผ่าน ${ok.length} · ต้องแก้ ${bad.length}</h5>
      <p>อัปเดตของเดิม ${known} คน · เพิ่มใหม่ ${ok.length-known} คน</p></div></div>
    ${bad.map(b=>`<div class="blk"><span class="sev block">แถว ${b.row}</span>
      <div><h5>${b.name||'(ไม่มีชื่อ)'} ${b.code?'· '+b.code:''}</h5>
        <p>${b.errs.join(' · ')}</p></div></div>`).join('')}
    ${bad.length?'':'<div class="blk"><span class="sev ok">OK</span><div><h5>ไม่มีข้อผิดพลาด</h5><p>กด “นำเข้าจริง” เพื่อบันทึก</p></div></div>'}`;
  document.getElementById('dry').classList.remove('hide');
}

function applyImport(){
  if(!staged) return;
  let upd=0, add=0;
  staged.ok.forEach(x=>{
    const r=x.raw;
    let e = EMP.find(v=>v.code===x.code);
    if(!e){
      /* Blank code -> issue the next one and REPORT it. Never silently. */
      const code = x.code || 'SEUS'+String(168+add).padStart(3,'0');
      e = {id:code, code, name:x.name, nick:r[COLS.nick]||'', pos:r[COLS.pos]||'',
        basis:'monthly', freq:'monthly', base:0, alw:{'ตำแหน่ง':0,'ประสบการณ์':0,'โทรศัพท์':0,'น้ำมัน':0},
        cls:'direct', exemptAtt:false, exemptSso:false, ssoReason:'', isDirector:false,
        nid:'', bank:'', acc:'', ssoNo:'', children:null, spouse:false,
        punches:[], face:null, projectId:null, status:'', hire:''};
      EMP.push(e); add++;
    } else upd++;

    e.pos    = r[COLS.pos] || e.pos;
    e.nid    = String(r[COLS.nid]||'').replace(/\D/g,'');
    e.basis  = String(r[COLS.basis]).includes('รายวัน') ? 'daily' : 'monthly';
    e.freq   = String(r[COLS.freq]).trim()==='วิค' ? 'semi' : 'monthly';   // "วิค" = ครึ่งเดือน
    e.base   = x.base;
    e.alw    = {'ตำแหน่ง':+r[COLS.a1]||0, 'ประสบการณ์':+r[COLS.a2]||0,
                'โทรศัพท์':+r[COLS.a3]||0, 'น้ำมัน':+r[COLS.a4]||0};
    recalc(e);
  });
  toast('ok', `นำเข้าสำเร็จ — อัปเดต ${upd} คน · เพิ่มใหม่ ${add} คน`);
  document.getElementById('dry').classList.add('hide');
  staged=null; save(); render(); summary(); board(); timesheet(); kycList();
  tab('s');
}

/* The template IS the file they already keep. Same sheet name, same headers,
   same row 3. A template that forces HR to rebuild their register is a template
   that will be ignored. */
function dlTemplate(){
  const hdr = Object.values(COLS);
  const ws = XLSX.utils.aoa_to_sheet([
    ['SEUS Engineering — ทะเบียนประวัติพนักงาน'],
    ['หัวตารางอยู่แถวที่ 3 · ห้ามสลับลำดับคอลัมน์ · วันที่ = YYYY-MM-DD · เลขบัตร 13 หลักไม่มีขีด · ค่าแรงเป็นตัวเลขล้วน'],
    hdr,
    ['SEUS168','นาย','สมชาย','ใจดี','ชาย','ช่างไฟฟ้า','1103700123456','1990-05-12','ชาย','0812345678',
     '2026-01-15','รายวัน','วิค','ประจำ',600,0,0,0,0],
  ]);
  ws['!cols'] = hdr.map(h=>({wch: Math.max(12, Math.min(22, h.length+4))}));
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Database');
  XLSX.writeFile(wb, 'SEUS_ทะเบียนพนักงาน_template.xlsx');
}

/* ── Summary ── */
function summary(){
  const S=(a,f)=>a.reduce((s,x)=>s+f(x),0);
  document.getElementById('s-cnt').textContent = `พนักงาน ${EMP.length} คน · รอบ 2026-07`;
  document.getElementById('s-g').textContent = M(S(EMP,e=>e.gross));
  document.getElementById('s-e').textContent = M(S(EMP,e=>e.ssoEmployer));
  document.getElementById('s-n').textContent = M(S(EMP,e=>e.net));

  document.getElementById('s-x').innerHTML = EMP.filter(e=>e.exemptSso).map(e=>`<tr>
    <td><b>${e.name}</b></td><td style="color:var(--ink-3)">${e.pos}</td>
    <td><span class="chip ${e.isDirector?'i':'a'}">${e.ssoReason}</span></td>
    <td class="num" style="color:var(--green)">0.00</td>
    <td class="num" style="color:var(--green)">0.00</td></tr>`).join('') +
    `<tr style="background:#F7FBFC"><td colspan="3"><b>ลูกจ้างที่หัก ปกส. ตามปกติ</b></td>
     <td class="num"><b>${M(S(EMP,e=>e.sso))}</b></td><td class="num"><b>${M(S(EMP,e=>e.ssoEmployer))}</b></td></tr>`;

  const d=EMP.filter(e=>e.cls==='direct'), o=EMP.filter(e=>e.cls==='overhead');
  document.getElementById('s-c').innerHTML = [
    ['ต้นทุนโครงการ', d, 'Cost of Sales — เหนือเส้นกำไรขั้นต้น'],
    ['ค่าดำเนินงาน',  o, 'Operating Expense — ใต้เส้นกำไรขั้นต้น'],
  ].map(([n,a,w])=>`<tr><td>${n}</td><td class="num">${a.length}</td>
    <td class="num">${M(S(a,e=>e.gross))}</td><td class="num">${M(S(a,e=>e.ssoEmployer))}</td>
    <td class="num" style="color:var(--indigo);font-weight:600">${M(S(a,cost))}</td>
    <td style="color:var(--ink-3);font-size:12.5px">${w}</td></tr>`).join('');

  const noKyc=EMP.filter(e=>!e.face).length, nb=EMP.filter(e=>!e.bank).length,
        nc=EMP.filter(e=>e.children===null).length, ns=EMP.filter(e=>!e.ssoNo&&!e.exemptSso).length,
        nn=EMP.filter(e=>!nidOk(e.nid)).length, npj=EMP.filter(e=>!projOf(e)).length;

  document.getElementById('s-b').innerHTML = [
    noKyc && ['block',`ยังไม่ลงทะเบียนใบหน้า — ${noKyc} คน`,'ลงเวลาด้วยใบหน้าไม่ได้'],
    npj && ['block',`ยังไม่มีโครงการ (ไม่เคยลงเวลา) — ${npj} คน`,'ต้นทุนไม่มีที่ลง และจะไหลไปเป็นค่าดำเนินงานเงียบ ๆ ทำหนึ่งปี กำไรขั้นต้นทุกโครงการที่รายงานคือเรื่องแต่ง'],
    nb && ['block',`ไม่มีเลขบัญชีธนาคาร — ${nb} คน`,'จ่ายเงินไม่ได้'],
    nc && ['block',`ไม่ได้ระบุจำนวนบุตร — ${nc} คน`,'ไม่ใช่ “ปลอดภัยไว้ก่อน” — มันหักภาษีเกิน ช่างที่มีลูก 2 คนและคู่สมรสไม่มีรายได้ เสียลดหย่อน 120,000/ปี เขาได้คืนตอนยื่นเดือนมีนาคม แต่เขาต้องใช้เงินตอนพฤศจิกายน'],
    nn && ['warn',`เลขบัตรประชาชนไม่ผ่าน checksum — ${nn} คน`,'ตรวจ 13 หลัก'],
    ns && ['warn',`ไม่มีเลข ปกส. — ${ns} คน`,'จ่ายเงินได้ แต่ยื่น สปส.1-10 ไม่ได้'],
    ['ok','กรรมการ 3 คนเป็นนายจ้าง — ไม่หัก ปกส. ทั้งสองฝั่ง','บุญมา · อาณัติ · อรรถพล — ตัดทั้งฝั่งหักและฝั่งสมทบนายจ้าง เพราะเงินสมทบนายจ้างเป็นต้นทุนบริษัท ไม่ใช่รายการหัก ตัดแค่ฝั่งเดียวจะพองต้นทุนไปตลอด'],
    ['ok','Back Office — ชั่วโมงรวมกับทีมบัญชี','คนรอประมูลงานไม่ได้ว่าง ชั่วโมงของเขาคือต้นทุนจริง ถ้าไม่มีที่ลงมันจะหายไปในค่าโสหุ้ยเงียบ ๆ แล้วคุณจะตั้งราคางานถัดไปไม่ถูก'],
    ['warn','จ่ายครึ่งเดือน 28 คน — กับดักหักซ้ำ','ปกส. เพดาน 750 บาท/เดือน หักทั้งสองงวด = เกินกฎหมายเท่าตัว ระบบหักเฉพาะงวดที่ 2 บนฐานรวมทั้งเดือน'],
  ].filter(Boolean).map(([s,t,dd])=>`<div class="blk"><span class="sev ${s}">${s.toUpperCase()}</span>
    <div><h5>${t}</h5><p>${dd}</p></div></div>`).join('');
}

function tab(t){
  ['c','k','p','t','i','s'].forEach(k=>{
    document.getElementById('v-'+k).classList.toggle('hide', k!==t);
    document.getElementById('t-'+k).setAttribute('aria-selected', k===t);
  });
  if(t!=='c' && t!=='k'){ clearInterval(detLoop); stream?.getTracks().forEach(x=>x.stop()); stream=null; }
}

setInterval(()=>{ const d=new Date();
  document.getElementById('clk').textContent=`${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`; },1000);

if(!window.isSecureContext) document.getElementById('ctx').classList.remove('hide');
load(); render(); summary(); board(); timesheet(); kycList();
</script>

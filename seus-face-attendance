/* ── Persistence: try localStorage; fall back to memory + manual save.
      A tool that forgets everything on refresh is not a tool. ── */
const KEY='seus.v1';
function save(){
  try{ localStorage.setItem(KEY, JSON.stringify(EMP.map(e=>({
        id:e.id, code:e.code, nid:e.nid, bank:e.bank, acc:e.acc, ssoNo:e.ssoNo,
        children:e.children, spouse:e.spouse, base:e.base, alw:e.alw,
        face:e.face, punches:e.punches, projectId:e.projectId}))));
      toast('ok','บันทึกแล้ว'); }
  catch(err){ dl(); }
}
function load(){
  try{
    const raw = localStorage.getItem(KEY); if(!raw) return;
    JSON.parse(raw).forEach(s=>{ const e=EMP.find(x=>x.id===s.id); if(e) Object.assign(e,s); });
    EMP.forEach(recalc);
  }catch(err){}
}
function dl(){
  const b=new Blob([JSON.stringify(EMP,null,2)],{type:'application/json'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(b);
  a.download='seus-'+dstr(new Date())+'.json'; a.click();
}

